{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agents-sak/openproject/relation",
  "title": "OpenProject Relation — Sentinels Validation Schema",
  "description": "Schema para validar relaciones entre Work Packages antes de crearlas.",
  "type": "object",
  "required": ["from_id", "to_id", "type"],
  "properties": {
    "from_id": {
      "type": "integer",
      "minimum": 1,
      "description": "ID del WP origen"
    },
    "to_id": {
      "type": "integer",
      "minimum": 1,
      "description": "ID del WP destino"
    },
    "type": {
      "type": "string",
      "enum": ["relates", "blocks", "precedes", "requires", "duplicates", "includes"],
      "description": "Tipo de relación (dirección: from → to)"
    },
    "lag": {
      "type": "integer",
      "minimum": 0,
      "description": "Días de lag entre from y to (solo para precedes/follows)"
    },
    "description": {
      "type": "string",
      "maxLength": 500,
      "description": "Explicación de por qué existe esta relación"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "type": { "enum": ["precedes"] } }
      },
      "then": {
        "properties": {
          "lag": { "type": "integer", "minimum": 0 }
        }
      }
    }
  ],
  "not": {
    "properties": {
      "from_id": { "$data": "1/to_id" }
    },
    "description": "from_id y to_id no pueden ser iguales (self-relation)"
  }
}
